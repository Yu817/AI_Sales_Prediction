{
  "name": "decision-intelligence-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-data": "node scripts/prepare-local-lstm-data.js",
    "sync-lstm:dry-run": "node scripts/sync-lstm-to-supabase.js --dry-run",
    "sync-lstm:supabase": "node scripts/sync-lstm-to-supabase.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "set RUN_EXPRESS_SERVER=true&& nodemon server/app.js",
    "server:start": "set RUN_EXPRESS_SERVER=true&& node server/app.js",
    "client:dev": "npm run prepare-data && vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "npm run prepare-data && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "recharts": "^2.15.0",
    "vite": "^6.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
